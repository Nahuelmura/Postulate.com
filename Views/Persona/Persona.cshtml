    <h1>Prueba de Tabla de Usuario</h1>
    <form id="formulario" >
        <div class="row">
            <input type="hidden" id="PersonaID" value="0" />
            <div class="form-group col-12">
                <label for="ProvinciaID" class="form-label">Provincia</label>
                @Html.DropDownList("ProvinciaID", null, htmlAttributes: new { @class = "form-control" })
            </div>

            <div class="form-group col-12">
                <label for="LocalidadID" class="form-label">Ciudad</label>
                @Html.DropDownList("LocalidadID", null, htmlAttributes: new { @class = "form-control" })
            </div>

            <div class="form-group col-12">
                <label for="nombre" class="form-label">Ingresar Nombre</label>
                <input type="text" id="nombre" name="nombre" class="form-control" placeholder="Ingresar Nombre">
            </div>

            <div class="form-group col-12">
                <label for="apellido" class="form-label">Ingresar Apellido</label>
                <input type="text" id="apellido" name="apellido" class="form-control" placeholder="Apellido">
            </div>

            <div class="form-group col-12">
                <label for="edad" class="form-label">Ingresar Edad</label>
                <input type="number" name="edad" id="edad" class="form-control" placeholder="Edad">
            </div>

            <div class="form-group col-12">
                <label for="telefono" class="form-label">Ingresar Teléfono</label>
                <input type="number" id="telefono" name="telefono" class="form-control" placeholder="Teléfono">
            </div>

            <div class="form-group col-12">
                <label for="documento" class="form-label">Ingresar Documento</label>
                <input type="number" id="documento" name="documento" class="form-control" placeholder="Documento">
            </div>

            <div class="form-group col-12">
                <label for="correo" class="form-label">Ingresar Correo</label>
                <input type="email" id="correo" name="correo" class="form-control" placeholder="Correo">
            </div>

                <div class="form-group col-12">
                <button type="submit" class="btn btn-secondary" onclick="Guardar();">Guardar</button>
            </div>
        </div>
      
    </form>


  <div class="mb-2 text-center">
  <button type="button" class="btn btn-primary botones" data-bs-toggle="modal" data-bs-target="#ModalFormulario" onclick="AbrirModalEditar()">
    <i class="fa-light fa-newspaper"></i>Editar
  </button>
  
</div>

<!-- Modal -->
<div class="modal fade" id="ModalFormulario" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="ModalTitulo"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="form-group row">
          <div class="col-12 mb-3">
            <label for="LocalidadID" class="form-label">Ciudad</label>
            @Html.DropDownList("LocalidadID", null, htmlAttributes: new { @class = "form-control" })
          </div>
          <div class="col-12 mb-3">
            <label for="ProvinciaID" class="form-label">Tipo de Ejercicio</label>
            @Html.DropDownList("ProvinciaID", null, htmlAttributes: new { @class = "form-control" })
          </div>
        </div>
        <div class="form-group row">
          <div class="col-12 mb-3">
            <label for="nombre" class="form-label">Nombre</label>
            <input type="text" class="form-control" id="nombre" placeholder="Nombre">
          </div>
          <div class="col-12 mb-3">
            <label for="apellido" class="form-label">Apellido</label>
            <input type="text" class="form-control" id="apellido" placeholder="Apellido">
          </div>
          <div class="col-12 mb-3">
            <label for="edad" class="form-label">Edad</label>
            <input type="number" class="form-control" id="edad" placeholder="Edad">
          </div>
          <div class="col-12 mb-3">
            <label for="telefono" class="form-label">Teléfono</label>
            <input type="number" class="form-control" id="telefono" placeholder="Teléfono">
          </div>
          <div class="col-12 mb-3">
            <label for="documento" class="form-label">Documento</label>
            <input type="number" class="form-control" id="documento" placeholder="Documento">
          </div>
          <div class="col-12 mb-3">
            <label for="correo" class="form-label">Correo</label>
            <input type="email" class="form-control" id="correo" placeholder="Correo">
          </div>
          <div class="col-12 mb-3">
            <label for="codigoPostal" class="form-label">Código Postal</label>
            <input type="text" class="form-control" id="codigoPostal" placeholder="Código Postal">
          </div>
        </div>
          <button type="button" onclick="LimpiarModal();" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onclick="GuardarLocalidad()">Guardar</button>
      </div>
    </div>
  </div>
</div>


      </div>
      <div class="modal-footer">
      
      </div>
    </div>
  </div>
</div>





    




@section Scripts {
  
   <script src="~/js/Persona.1.0.0.js"></script>
}
